# Public configuration consumed by the browser. Anything prefixed with
# NEXT_PUBLIC_ is bundled into the client; secrets must NOT live here.

# Base URL of the mneme FastAPI backend. Defaults to the local server.
# When deploying the frontend on Vercel and running the backend on your
# own machine, set this to the tunnelled URL (e.g., a ngrok or
# tailscale-funnel address pointing at port 8000).
NEXT_PUBLIC_API_BASE=http://localhost:8000
